# Government Opportunity Intelligence — single Vercel project (Root Directory =
# website). One deployment serves the marketing site, the GOIR report, AND the
# operator leads dashboard at /leads.

# --- Database (same Supabase project as Kingsway OS) ---
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- One-time setup: visit /api/setup?token=<this> once to create the
#     GoirReport table on the shared database. ---
SETUP_TOKEN="change-me-to-a-long-random-string"

# --- Public site URL (used as the report-link origin in emails) ---
NEXT_PUBLIC_SITE_URL="https://www.governmentopportunityintelligence.com"

# --- AI narrative layer (optional — report works fully without it) ---
ANTHROPIC_API_KEY=""

# --- Transactional email via Resend (optional — emails skipped if unset) ---
RESEND_API_KEY=""
EMAIL_FROM="GOIR <reports@yourdomain.com>"

# --- Operator dashboard at /leads (required to enable it) ---
LEADS_PASSWORD="choose-a-strong-password"

# --- Only if you ever host the report app on a SEPARATE domain ---
# Leave unset: the report lives on this site at /report.
# NEXT_PUBLIC_REPORT_URL=""
