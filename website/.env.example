# Government Opportunity Intelligence — marketing/SEO site env.
# This is a static marketing site (no database). Deploy as its own Vercel
# project with Root Directory = website.

# URL of the interactive GOIR report app (the separate `goir/` deployment).
# When set, every "Get your free report" CTA funnels straight into the live
# assessment. Leave empty to keep CTAs on the internal landing page.
NEXT_PUBLIC_REPORT_URL="https://your-goir-site.vercel.app"
