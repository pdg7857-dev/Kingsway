# Government Opportunity Intelligence — single Vercel project (Root Directory =
# website). One deployment serves the marketing site, the GOIR report, AND the
# operator leads dashboard at /leads.

# --- Database (same Supabase project as Kingsway OS) ---
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- One-time setup: visit /api/setup?token=<this> once to create the
#     GoirReport table on the shared database. ---
SETUP_TOKEN="change-me-to-a-long-random-string"

# --- Public site URL (used as the report-link origin in emails) ---
NEXT_PUBLIC_SITE_URL="https://phildave.com"

# --- AI narrative layer (optional — report works fully without it) ---
ANTHROPIC_API_KEY=""

# --- Transactional email via Resend (optional — emails skipped if unset) ---
RESEND_API_KEY=""
EMAIL_FROM="GOIR <reports@yourdomain.com>"

# --- Operator dashboard at /leads (required to enable it) ---
LEADS_PASSWORD="choose-a-strong-password"

# --- GOIR lead magnet master switch ---
# Off by default: /report + /access redirect to booking and all CTAs point to
# the discovery call. Set to "true" to turn the interactive report back on.
NEXT_PUBLIC_GOIR_ENABLED="false"

# --- Only if you ever host the report app on a SEPARATE domain ---
# Leave unset: the report lives on this site at /report.
# NEXT_PUBLIC_REPORT_URL=""

# --- Analytics ---
# Microsoft Clarity: click/scroll heatmaps, session recordings, and geography.
# Create a free project at https://clarity.microsoft.com, then paste the
# project ID here (the "xxxxxxxxxx" from the install snippet). Until set, no
# Clarity script loads.
NEXT_PUBLIC_CLARITY_ID=""
# Vercel Analytics + Speed Insights need no keys — enable them in the Vercel
# project's Analytics tab and they start collecting on the next deploy.
