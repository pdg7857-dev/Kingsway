// CEO Command OS — Prisma schema
// Money is stored as integer cents.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum BusinessSlug {
  lexus
  fitness
  content
  phone_repair
  supplements
  personal
  eprocurement
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  WAITING
  DONE
  CANCELLED
}

enum RecurrenceFreq {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum DealStage {
  LEAD
  CONTACTED
  QUALIFIED
  TEST_DRIVE
  NEGOTIATION
  WON
  LOST
}

enum LeadSource {
  WEBSITE
  REFERRAL
  WALK_IN
  AD
  SOCIAL
  MARKETPLACE
  OTHER
}

enum ExpenseStatus {
  PENDING
  PAID
  OVERDUE
}

enum PaymentMethod {
  CASH
  DEBIT
  CREDIT_CARD
  ACH
  ZELLE
  WIRE
  CHECK
  CRYPTO
  OTHER
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  SLACK
  PUSH
}

enum NotificationKind {
  TASK_OVERDUE
  BILL_DUE
  CARD_DUE
  INVOICE_UNPAID
  FOLLOW_UP
  EMAIL_IMPORTANT
  MESSAGE_IMPORTANT
  INVENTORY_LOW
  CASH_FLOW
  CHECKIN_OVERDUE
  CUSTOMER_WAITING
  COST_UPCOMING
  CONTENT_REMINDER
  GENERIC
}

enum RepairStatus {
  RECEIVED
  DIAGNOSED
  IN_REPAIR
  AWAITING_PARTS
  READY
  DELIVERED
  CANCELLED
}

enum OrderChannel {
  WEBSITE
  MAIL_IN
  PICKUP
  MARKETPLACE
  WHOLESALE
  OTHER
}

enum ContentPlatform {
  INSTAGRAM
  TIKTOK
  YOUTUBE
  FACEBOOK
  X
  LINKEDIN
}

enum ContentStatus {
  IDEA
  SCRIPTED
  FILMED
  EDITING
  SCHEDULED
  POSTED
  ARCHIVED
}

enum FitnessClientStatus {
  LEAD
  ONBOARDING
  ACTIVE
  PAUSED
  CHURNED
}

enum IdeaStatus {
  INBOX
  EXPLORING
  VALIDATED
  CONVERTED
  ARCHIVED
}

enum MileagePurpose {
  BUSINESS
  PERSONAL
}

enum ProcurementStatus {
  LEAD
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
  ACTIVE
  PAUSED
  CHURNED
}

enum GovContractStatus {
  FOUND
  SUMMARIZED
  SENT
  PURCHASED
  PASSED
}

enum AgentKind {
  MASTER
  FINANCE
  EMAIL
  CALENDAR
  SALES
  FITNESS
  CONTENT
  PHONE_REPAIR
  SUPPLEMENT
  EPROCUREMENT
  PERSONAL
}

enum InsightKind {
  DAILY_BRIEFING
  WEEKLY_REVIEW
  MONTHLY_REPORT
  RISK_ALERT
  OPPORTUNITY
  SUMMARY
  ACTION_TAKEN
}

enum AutomationTriggerKind {
  CRON
  EMAIL_RECEIVED
  WHATSAPP_RECEIVED
  TASK_CREATED
  TASK_OVERDUE
  EXPENSE_CREATED
  BILL_DUE_SOON
  INVENTORY_LOW
  DEAL_STAGE_CHANGED
  FITNESS_CHECKIN_OVERDUE
  CONTENT_SCHEDULED
  MANUAL
}

// ─────────────────────────────────────────────────────────────
// Auth / Core
// ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  timezone      String    @default("America/Los_Angeles")
  aiMonthlyBudgetCents Int @default(2000)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  businesses        Business[]
  tasks             Task[]
  projects          Project[]
  ideas             Idea[]
  contacts          Contact[]
  customers         Customer[]
  leads             Lead[]
  deals             Deal[]
  calendarEvents    CalendarEvent[]
  notifications     Notification[]
  expenses          Expense[]
  revenues          Revenue[]
  creditCards       CreditCard[]
  bills             Bill[]
  inventoryItems    InventoryItem[]
  orders            Order[]
  repairTickets     RepairTicket[]
  fitnessClients    FitnessClient[]
  contentItems      ContentItem[]
  supplementProducts SupplementProduct[]
  supplementOrders  SupplementOrder[]
  aiInsights        AIInsight[]
  aiConversations   AIConversation[]
  emailImports      EmailImport[]
  whatsAppMessages  WhatsAppMessage[]
  automations       Automation[]
  reports           Report[]
  documents         Document[]
  habits            Habit[]
  goals             Goal[]
  financialAccounts FinancialAccount[]
  mileageLogs       MileageLog[]
  procurementClients ProcurementClient[]
  govContracts      GovContract[]
  integrationCredentials IntegrationCredential[]
  aiUsage           AIUsage[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Business {
  id          String       @id @default(cuid())
  userId      String
  slug        BusinessSlug
  name        String
  description String?
  color       String?
  emoji       String?
  archived    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks             Task[]
  projects          Project[]
  ideas             Idea[]
  customers         Customer[]
  leads             Lead[]
  deals             Deal[]
  expenses          Expense[]
  revenues          Revenue[]
  bills             Bill[]
  calendarEvents    CalendarEvent[]
  inventoryItems    InventoryItem[]
  orders            Order[]
  contentItems      ContentItem[]
  notifications     Notification[]
  aiInsights        AIInsight[]
  repairTickets     RepairTicket[]
  fitnessClients    FitnessClient[]
  supplementProducts SupplementProduct[]
  mileageLogs       MileageLog[]
  procurementClients ProcurementClient[]
  govContracts      GovContract[]

  @@unique([userId, slug])
}

// ─────────────────────────────────────────────────────────────
// Productivity
// ─────────────────────────────────────────────────────────────

model Task {
  id           String       @id @default(cuid())
  userId       String
  businessId   String?
  projectId    String?
  parentId     String?
  customerId   String?
  dealId       String?
  title        String
  description  String?
  status       TaskStatus   @default(TODO)
  priority     Priority     @default(MEDIUM)
  dueAt        DateTime?
  remindAt     DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  assignee     String?
  tags         String[]     @default([])
  recurrence   RecurrenceFreq @default(NONE)
  recurrenceUntil DateTime?
  relatedEmailId String?
  relatedMessageId String?
  source       String?      // ai, email, whatsapp, manual, voice
  aiRationale  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  archivedAt   DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id])
  project  Project?  @relation(fields: [projectId], references: [id])
  parent   Task?     @relation("Subtasks", fields: [parentId], references: [id])
  subtasks Task[]    @relation("Subtasks")
  customer Customer? @relation(fields: [customerId], references: [id])
  deal     Deal?     @relation(fields: [dealId], references: [id])

  @@index([userId, status])
  @@index([userId, businessId, dueAt])
  @@index([userId, dueAt])
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  businessId  String?
  name        String
  description String?
  status      String   @default("active")
  startedAt   DateTime?
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id])
  tasks    Task[]

  @@index([userId, businessId])
}

model Idea {
  id           String     @id @default(cuid())
  userId       String
  businessId   String?
  title        String
  body         String?
  status       IdeaStatus @default(INBOX)
  priority     Priority   @default(MEDIUM)
  aiExpansion  String?    @db.Text
  aiFeasibility Int?      // 0–100
  tags         String[]   @default([])
  convertedToTaskId    String?
  convertedToProjectId String?
  convertedToContentId String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id])

  @@index([userId, status])
  @@index([userId, businessId])
}

// ─────────────────────────────────────────────────────────────
// CRM
// ─────────────────────────────────────────────────────────────

model Contact {
  id        String   @id @default(cuid())
  userId    String
  firstName String
  lastName  String?
  email     String?
  phone     String?
  whatsapp  String?
  company   String?
  notes     String?
  birthday  DateTime?
  tags      String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  customers Customer[]
  leads     Lead[]

  @@index([userId])
}

model Customer {
  id          String   @id @default(cuid())
  userId      String
  contactId   String?
  businessId  String?
  name        String
  email       String?
  phone       String?
  notes       String?
  totalSpentCents Int  @default(0)
  ltv         Int      @default(0)
  lastTouchAt DateTime?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id])
  contact  Contact?  @relation(fields: [contactId], references: [id])
  tasks    Task[]
  deals    Deal[]
  orders   Order[]
  repairs  RepairTicket[]

  @@index([userId, businessId])
}

model Lead {
  id         String     @id @default(cuid())
  userId     String
  businessId String?
  contactId  String?
  name       String
  email      String?
  phone      String?
  source     LeadSource @default(OTHER)
  status     String     @default("new")
  notes      String?
  scoredAt   DateTime?
  score      Int?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id])
  contact  Contact?  @relation(fields: [contactId], references: [id])
  deals    Deal[]

  @@index([userId, businessId, status])
}

model Deal {
  id          String    @id @default(cuid())
  userId      String
  businessId  String?
  customerId  String?
  leadId      String?
  title       String
  stage       DealStage @default(LEAD)
  valueCents  Int       @default(0)
  costCents   Int       @default(0)
  probability Int       @default(50)
  expectedCloseAt DateTime?
  closedAt    DateTime?
  nextAction  String?
  nextActionAt DateTime?
  notes       String?
  vehicle     String?  // Lexus-specific freeform
  tradeIn     String?  // Lexus-specific freeform
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  lead     Lead?     @relation(fields: [leadId], references: [id])
  tasks    Task[]

  @@index([userId, stage])
  @@index([userId, businessId])
}

// ─────────────────────────────────────────────────────────────
// Calendar / Notifications
// ─────────────────────────────────────────────────────────────

model CalendarEvent {
  id          String   @id @default(cuid())
  userId      String
  businessId  String?
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  allDay      Boolean  @default(false)
  location    String?
  source      String   @default("internal") // internal | google | bill | task
  externalId  String?
  attendees   String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id])

  @@index([userId, startAt])
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  businessId String?
  kind      NotificationKind
  title     String
  body      String?
  channels  NotificationChannel[]
  data      Json?
  readAt    DateTime?
  sentAt    DateTime?
  createdAt DateTime            @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id])

  @@index([userId, readAt])
}

// ─────────────────────────────────────────────────────────────
// Finance
// ─────────────────────────────────────────────────────────────

model Expense {
  id            String         @id @default(cuid())
  userId        String
  businessId    String?
  vendor        String
  description   String?
  amountCents   Int
  taxCents      Int?
  currency      String         @default("USD")
  date          DateTime
  dueAt         DateTime?
  status        ExpenseStatus  @default(PAID)
  paymentMethod PaymentMethod  @default(CREDIT_CARD)
  creditCardId  String?
  recurrence    RecurrenceFreq @default(NONE)
  category      String?
  aiCategory    String?
  taxCategory   String?
  notes         String?
  receiptUrl    String?
  isUpcoming    Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  business   Business?   @relation(fields: [businessId], references: [id])
  creditCard CreditCard? @relation(fields: [creditCardId], references: [id])

  @@index([userId, date])
  @@index([userId, businessId, date])
  @@index([userId, status])
}

model Revenue {
  id          String   @id @default(cuid())
  userId      String
  businessId  String?
  source      String
  description String?
  amountCents Int
  currency    String   @default("USD")
  date        DateTime
  customerId  String?
  orderId     String?
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id])

  @@index([userId, date])
  @@index([userId, businessId, date])
}

model CreditCard {
  id              String   @id @default(cuid())
  userId          String
  name            String
  last4           String
  network         String?  // visa, amex, etc.
  limitCents      Int      @default(0)
  balanceCents    Int      @default(0)
  apr             Float?
  statementDay    Int?
  paymentDueDay   Int?
  nextStatementAt DateTime?
  nextDueAt       DateTime?
  minPaymentCents Int?
  color           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses Expense[]
  bills    Bill[]
}

model Bill {
  id          String         @id @default(cuid())
  userId      String
  businessId  String?
  creditCardId String?
  vendor      String
  description String?
  amountCents Int
  dueAt       DateTime
  status      ExpenseStatus  @default(PENDING)
  recurrence  RecurrenceFreq @default(MONTHLY)
  category    String?
  autopay     Boolean        @default(false)
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  business   Business?   @relation(fields: [businessId], references: [id])
  creditCard CreditCard? @relation(fields: [creditCardId], references: [id])

  @@index([userId, dueAt])
}

model FinancialAccount {
  id            String   @id @default(cuid())
  userId        String
  name          String
  kind          String   // checking, savings, brokerage, crypto, debt
  institution   String?
  balanceCents  Int      @default(0)
  currency      String   @default("USD")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────
// Inventory + Orders (cross-business)
// ─────────────────────────────────────────────────────────────

model InventoryItem {
  id            String   @id @default(cuid())
  userId        String
  businessId    String?
  sku           String?
  name          String
  description   String?
  quantity      Int      @default(0)
  reorderAt     Int      @default(0)
  costCents     Int      @default(0)
  priceCents    Int      @default(0)
  location      String?
  imei          String?  // phone-repair
  attributes    Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id])

  @@index([userId, businessId])
  @@index([userId, quantity])
}

model Order {
  id            String       @id @default(cuid())
  userId        String
  businessId    String?
  customerId    String?
  channel       OrderChannel @default(WEBSITE)
  status        String       @default("new")
  subtotalCents Int          @default(0)
  shippingCents Int          @default(0)
  taxCents      Int          @default(0)
  totalCents    Int          @default(0)
  trackingNumber String?
  notes         String?
  placedAt      DateTime     @default(now())
  fulfilledAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([userId, status])
}

// ─────────────────────────────────────────────────────────────
// Phone Repair
// ─────────────────────────────────────────────────────────────

model RepairTicket {
  id           String       @id @default(cuid())
  userId       String
  businessId   String?
  customerId   String?
  device       String
  imei         String?
  issue        String
  diagnosis    String?
  partsUsed    Json?
  status       RepairStatus @default(RECEIVED)
  channel      OrderChannel @default(MAIL_IN)
  quotedCents  Int          @default(0)
  finalCents   Int          @default(0)
  costCents    Int          @default(0)
  receivedAt   DateTime     @default(now())
  deliveredAt  DateTime?
  warrantyEndsAt DateTime?
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([userId, status])
}

// ─────────────────────────────────────────────────────────────
// Fitness coaching
// ─────────────────────────────────────────────────────────────

model FitnessClient {
  id            String              @id @default(cuid())
  userId        String
  businessId    String?
  name          String
  email         String?
  phone         String?
  goal          String?
  programName   String?
  coachName     String?
  status        FitnessClientStatus @default(ACTIVE)
  mrrCents      Int                 @default(0)
  startedAt     DateTime?
  renewalAt     DateTime?
  lastCheckInAt DateTime?
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  business  Business?        @relation(fields: [businessId], references: [id])
  checkIns  FitnessCheckIn[]

  @@index([userId, status])
}

model FitnessCheckIn {
  id          String   @id @default(cuid())
  clientId    String
  date        DateTime @default(now())
  weightKg    Float?
  bodyFatPct  Float?
  energy      Int?     // 1–10
  adherence   Int?     // 1–10
  notes       String?
  photosCount Int      @default(0)
  createdAt   DateTime @default(now())

  client FitnessClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, date])
}

// ─────────────────────────────────────────────────────────────
// Content
// ─────────────────────────────────────────────────────────────

model ContentItem {
  id          String          @id @default(cuid())
  userId      String
  businessId  String?
  platform    ContentPlatform
  status      ContentStatus   @default(IDEA)
  hook        String?
  caption     String?         @db.Text
  script      String?         @db.Text
  thumbnailUrl String?
  scheduledAt DateTime?
  postedAt    DateTime?
  externalUrl String?
  tags        String[]        @default([])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  business  Business?         @relation(fields: [businessId], references: [id])
  analytics SocialAnalytics[]

  @@index([userId, platform, scheduledAt])
  @@index([userId, status])
}

model SocialAnalytics {
  id            String          @id @default(cuid())
  contentItemId String
  platform      ContentPlatform
  views         Int             @default(0)
  likes         Int             @default(0)
  comments      Int             @default(0)
  shares        Int             @default(0)
  saves         Int             @default(0)
  followsGained Int             @default(0)
  revenueCents  Int             @default(0)
  capturedAt    DateTime        @default(now())

  content ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@index([contentItemId, capturedAt])
}

// ─────────────────────────────────────────────────────────────
// Supplements
// ─────────────────────────────────────────────────────────────

model SupplementProduct {
  id            String   @id @default(cuid())
  userId        String
  businessId    String?
  name          String
  sku           String?
  costCents     Int      @default(0)
  priceCents    Int      @default(0)
  inventory     Int      @default(0)
  reorderAt     Int      @default(0)
  subscriptionEnabled Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id])
  orders   SupplementOrder[]
}

model SupplementOrder {
  id          String   @id @default(cuid())
  userId      String
  productId   String
  customerName String?
  totalCents  Int      @default(0)
  subscription Boolean @default(false)
  placedAt    DateTime @default(now())
  createdAt   DateTime @default(now())

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  product SupplementProduct @relation(fields: [productId], references: [id])

  @@index([userId, placedAt])
}

// ─────────────────────────────────────────────────────────────
// Personal
// ─────────────────────────────────────────────────────────────

model Habit {
  id          String   @id @default(cuid())
  userId      String
  name        String
  cadence     String   @default("daily")
  streak      Int      @default(0)
  longest     Int      @default(0)
  lastDoneAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id          String   @id @default(cuid())
  userId      String
  title       String
  area        String?
  description String?
  targetDate  DateTime?
  progress    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────
// AI / messages / automations
// ─────────────────────────────────────────────────────────────

model AIInsight {
  id         String      @id @default(cuid())
  userId     String
  businessId String?
  agent      AgentKind
  kind       InsightKind
  title      String
  summary    String      @db.Text
  payload    Json?
  createdAt  DateTime    @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id])

  @@index([userId, createdAt])
}

model AIConversation {
  id        String      @id @default(cuid())
  userId    String
  agent     AgentKind   @default(MASTER)
  title     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  messages  AIMessage[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AIMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // user | assistant | system | tool
  content        String   @db.Text
  toolName       String?
  toolPayload    Json?
  createdAt      DateTime @default(now())

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model EmailImport {
  id         String   @id @default(cuid())
  userId     String
  threadId   String?
  messageId  String   @unique
  from       String
  to         String[]
  subject    String?
  snippet    String?
  body       String?  @db.Text
  importance Int      @default(0) // 0–5
  isTask     Boolean  @default(false)
  taskId     String?
  receivedAt DateTime
  labels     String[] @default([])
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, receivedAt])
}

model WhatsAppMessage {
  id           String   @id @default(cuid())
  userId       String
  contactPhone String
  contactName  String?
  direction    String   // inbound | outbound
  body         String   @db.Text
  importance   Int      @default(0)
  isTask       Boolean  @default(false)
  taskId       String?
  receivedAt   DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, receivedAt])
}

model Automation {
  id          String                @id @default(cuid())
  userId      String
  name        String
  description String?
  trigger     AutomationTriggerKind
  config      Json
  actions     Json
  enabled     Boolean               @default(true)
  lastRunAt   DateTime?
  lastResult  String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, enabled])
}

model Report {
  id        String   @id @default(cuid())
  userId    String
  kind      String   // daily | weekly | monthly | business | pipeline | content | retention | inventory
  scope     String?
  title     String
  body      String   @db.Text
  payload   Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Document {
  id        String   @id @default(cuid())
  userId    String
  name      String
  url       String
  mime      String?
  size      Int?
  tags      String[] @default([])
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────
// Mileage tracker
// ─────────────────────────────────────────────────────────────

model MileageLog {
  id           String         @id @default(cuid())
  userId       String
  businessId   String?
  date         DateTime       @default(now())
  fromLocation String
  toLocation   String
  reason       String?
  miles        Float          @default(0)
  distanceKm   Float?
  transportMode String        @default("CAR") // CAR | TRAIN | PLANE | UBER | TAXI | RIDESHARE | BUS | OTHER
  purpose      MileagePurpose @default(BUSINESS)
  vehicle      String?
  ratePerMile  Float          @default(0.70)
  ratePerKm    Float?         @default(0.43)
  costCents    Int?           // for train/plane/uber fares
  roundTrip    Boolean        @default(false)
  odometerStart Float?
  odometerEnd   Float?
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id])

  @@index([userId, date])
  @@index([userId, purpose])
}

model AIUsage {
  id           String   @id @default(cuid())
  userId       String
  agent        String?
  model        String
  feature      String?  // chat | briefing | receipt | idea | contract | quickadd
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costCents    Float    @default(0)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model IntegrationCredential {
  id          String   @id @default(cuid())
  userId      String
  provider    String   // icloud | google
  label       String?
  username    String?
  secret      String?  // app-specific password / token
  calendarUrl String?
  remindersUrl String?
  data        Json?
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

// ─────────────────────────────────────────────────────────────
// eProcurement consulting
// ─────────────────────────────────────────────────────────────

model ProcurementClient {
  id            String            @id @default(cuid())
  userId        String
  businessId    String?
  name          String
  company       String?
  email         String?
  phone         String?
  industry      String?
  status        ProcurementStatus @default(LEAD)
  touchCount    Int               @default(0)
  touchesToSign Int?              // observed touches before they signed
  monthlyFeeCents Int             @default(25000) // $250/mo default
  businessInfo  String?           @db.Text
  notes         String?           @db.Text
  lostReason    String?
  signedAt      DateTime?
  lastTouchAt   DateTime?
  nextTouchAt   DateTime?
  renewalAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  business  Business?     @relation(fields: [businessId], references: [id])
  contracts GovContract[]

  @@index([userId, status])
  @@index([userId, industry])
}

model GovContract {
  id            String            @id @default(cuid())
  userId        String
  businessId    String?
  clientId      String?
  title         String
  agency        String?
  industry      String?
  solicitationNumber String?
  url           String?
  valueCents    Int?
  responseDueAt DateTime?
  summary       String?           @db.Text
  fitAssessment String?           @db.Text
  status        GovContractStatus @default(FOUND)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business?          @relation(fields: [businessId], references: [id])
  client   ProcurementClient? @relation(fields: [clientId], references: [id])

  @@index([userId, status])
  @@index([userId, industry])
}

// ─────────────────────────────────────────────────────────────
// Government Opportunity Intelligence Report™ (GOIR)
// Public lead-magnet assessments. No auth — captured from prospects.
// ─────────────────────────────────────────────────────────────

model GoirReport {
  id          String   @id @default(cuid())
  // Intake
  companyName String
  website     String?
  industry    String   // see src/lib/goir/industries.ts keys
  region      String   // province / state (free text or code)
  email       String
  contactName String?
  phone       String?
  platformsUsed   String[] @default([])
  annualBidVolume Int?
  employees       Int?
  // Computed headline
  index       Int      // Government Opportunity Intelligence Index™ 0–100
  tier        String   // Elite | Advanced | Strong | Developing | Emerging | At Risk
  scores      Json     // category breakdown { government, award, waste, ... }
  result      Json     // full computed report payload (all 10 sections)
  narrative   Json?    // optional AI-written prose layered on top
  // Manual delivery — prospect views the report with an access code Phil sends.
  accessCode    String   @unique
  status        String   @default("SUBMITTED") // SUBMITTED | DELIVERED | VIEWED
  deliveredAt   DateTime?
  firstViewedAt DateTime?
  // Lead lifecycle
  consultationRequested Boolean   @default(false)
  consultRequestedAt    DateTime?
  convertedClientId     String?
  source      String   @default("web")
  ipHash      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([industry, createdAt])
  @@index([status, createdAt])
  @@index([email])
}
