# Postgres (Supabase). pgvector can be enabled later for semantic search.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/opportunity_engine"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/opportunity_engine"

# Anthropic Claude, used for solicitation document analysis.
ANTHROPIC_API_KEY=""
# Latest Claude model id for analysis (Opus/Sonnet 4.x). Override as new models ship.
ANTHROPIC_MODEL="claude-sonnet-4-6"

# --- Operator authentication (run `npm run auth:setup` to generate these) ---
# Login password (factor 1).
OPERATOR_PASSWORD=""
# Base32 secret for the authenticator app, 2FA (factor 2).
TOTP_SECRET=""
# Long random string used to sign session cookies.
SESSION_SECRET=""

# Renewal forecasting: months before a contract end date to flag a re-bid window.
RENEWAL_LEAD_MONTHS="5"
