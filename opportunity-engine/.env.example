# Postgres (Supabase). pgvector can be enabled later for semantic search.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/opportunity_engine"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/opportunity_engine"

# Anthropic Claude, used for solicitation document analysis.
ANTHROPIC_API_KEY=""
# Latest Claude model id for analysis (Opus/Sonnet 4.x). Override as new models ship.
ANTHROPIC_MODEL="claude-sonnet-4-6"
# Per-1M-token prices used for the analysis cost estimate (defaults: 3 in / 15 out).
# ANTHROPIC_PRICE_IN="3"
# ANTHROPIC_PRICE_OUT="15"

# --- Operator authentication (run `npm run auth:setup` to generate these) ---
# Login password (factor 1).
OPERATOR_PASSWORD=""
# Base32 secret for the authenticator app, 2FA (factor 2).
TOTP_SECRET=""
# Long random string used to sign session cookies.
SESSION_SECRET=""

# Renewal forecasting: months before a contract end date to flag a re-bid window.
RENEWAL_LEAD_MONTHS="5"

# OCR for scanned PDFs (#4). On by default; needs tesseract-ocr + poppler-utils
# (the Docker image installs them). Set to "false" to disable OCR.
OCR_ENABLED="true"

# --- Semantic search (#8, optional). Needs pgvector on the DB + an embeddings
#     key, then run: npx tsx scripts/embed.ts ---
EMBEDDINGS_PROVIDER="voyage"            # "voyage" (default) or "openai"
VOYAGE_API_KEY=""
# EMBEDDING_MODEL="voyage-3-large"      # or voyage-law-2; for openai: text-embedding-3-large
# OPENAI_API_KEY=""                     # only if EMBEDDINGS_PROVIDER=openai
